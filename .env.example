# ============================================================================
#  Find My Trial — environment template
#  Copy to `.env` and fill in. `.env` is gitignored and must NEVER be committed.
# ============================================================================

# --- Secrets (REQUIRED) ---
# Used to sign session cookies. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
FMT_SECRET_KEY=change-me-to-a-long-random-string

# OpenRouter API key. The system is model-agnostic and routes through OpenRouter.
# Without a key, the app runs in DEGRADED mode (deterministic rule-based extraction,
# no LLM reranking). Get one at https://openrouter.ai/keys
FMT_OPENROUTER_API_KEY=

# --- LLM model selection (model-agnostic via OpenRouter) ---
# Cheaper/faster model for chart extraction:
FMT_LLM_EXTRACTION_MODEL=google/gemini-3.1-flash-lite
# Stronger model for the reasoning-heavy rerank/explain step (bump to a larger model if you want richer reasoning):
FMT_LLM_RERANK_MODEL=google/gemini-3.1-flash-lite
# Enforce Zero-Data-Retention routing on OpenRouter (only providers that retain nothing):
FMT_OPENROUTER_ENFORCE_ZDR=true

# --- Data ---
# Path to the public ClinicalTrials.gov-style trial corpus CSV.
FMT_TRIALS_CSV_PATH=data/trials.csv

# --- Auth / session ---
FMT_SESSION_IDLE_TIMEOUT_MINUTES=30
# Seed admin account created on first run. REQUIRED to log in — set a strong value.
# Leave blank and no account is seeded (the app starts but no one can authenticate).
FMT_ADMIN_USERNAME=admin
FMT_ADMIN_PASSWORD=

# --- Intake / de-identification ---
# Require a human to approve de-identified text before it leaves the machine (LLM call).
FMT_REQUIRE_DEID_REVIEW=true
# Use Presidio NER for de-id if installed (rule-based layer is always on regardless).
FMT_USE_PRESIDIO=false

# --- Runtime ---
FMT_ENV=development
FMT_CORS_ORIGINS=http://localhost:5173
FMT_MAX_UPLOAD_MB=15
